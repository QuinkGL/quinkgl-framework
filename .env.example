# QuinkGL Environment Configuration
# Copy this file to .env and uncomment the variables you want to override.

# ── Logging ──────────────────────────────────────────────────────────
# Controls the log level for the quinkgl logger.
# Values: DEBUG, INFO, WARNING (default), ERROR, CRITICAL
# QUINKGL_LOG_LEVEL=WARNING

# ── Tunnel Server (OPTIONAL) ────────────────────────────────────────
# Overrides the production default: quinkql-tunnel.duckdns.org:50051
# Only needed for local development or custom tunnel servers.
# Format: HOST:PORT
# Examples:
#   - Local development: localhost:50051
#   - Custom server: your-server.com:50051
# TUNNEL_SERVER=localhost:50051
