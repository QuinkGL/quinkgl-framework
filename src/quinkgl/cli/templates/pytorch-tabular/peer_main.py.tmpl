"""
Canonical Mode-C peer main for {project_name}.
Generated by QuinkGL v{quinkgl_version} ({template} template).
"""

import asyncio

from quinkgl.swarm import GossipNode, SwarmManifest

from peer_script import build_loaders, build_model


async def main() -> None:
    manifest = SwarmManifest.from_file("{manifest_filename}")
    node = GossipNode(
        manifest=manifest,
        build_model=build_model,
        build_loaders=build_loaders,
    )
    try:
        await node.start()
        await node.train()
    finally:
        await node.stop()


if __name__ == "__main__":
    asyncio.run(main())
